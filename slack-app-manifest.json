{
  "display_information": {
    "name": "flightrec",
    "description": "Privileged-action broker with a tamper-evident audit trail"
  },
  "features": {
    "bot_user": {
      "display_name": "flightrec",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/grant",
        "description": "Request privileged access (opens a form)",
        "should_escape": false
      },
      {
        "command": "/audit",
        "description": "Show a run's tamper-evident audit report",
        "usage_hint": "<runId>",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": ["commands", "chat:write"]
    }
  },
  "settings": {
    "interactivity": {
      "is_enabled": true
    },
    "socket_mode_enabled": true,
    "org_deploy_enabled": false,
    "token_rotation_enabled": false
  }
}
