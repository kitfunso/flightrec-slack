# flightrec-slack environment — copy to .env and fill in. .env is gitignored.

# Slack app (api.slack.com/apps → your app)
# Bot User OAuth Token — OAuth & Permissions (starts xoxb-)
SLACK_BOT_TOKEN=
# App-Level Token — Basic Information → App-Level Tokens, scope connections:write (starts xapp-)
SLACK_APP_TOKEN=
# Signing Secret — Basic Information → App Credentials
SLACK_SIGNING_SECRET=

# Anthropic API key for the agent loop (console.anthropic.com → API Keys; starts sk-ant-)
# Not needed to build/test M2 (the agent loop runs stubbed); only for the live demo.
ANTHROPIC_API_KEY=

# Demo-only: set to 1 to enable the `/audit tamper <runId>` command, which
# simulates an out-of-band attack so you can show the audit flip to BROKEN.
# Leave unset in any real deployment.
FLIGHTREC_DEMO=
